{
  "expo": {
    "name": "Maya Fitness",
    "slug": "maya-fitness",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "maya-runner",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#0D0D0D"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.mayafitness.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Maya Runner utilise ta localisation pour tracer tes courses en temps réel.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Maya Runner utilise ta localisation pour tracer tes courses.",
        "NSPhotoLibraryUsageDescription": "Maya Runner accède à tes photos pour enregistrer ta progression."
      }
    },
    "android": {
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Maya Runner utilise ta localisation pour tracer tes courses en temps réel."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Maya Runner accède à tes photos pour suivre ta progression."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "c07df32b-55e2-4cf9-a7ba-41e260c6b473"
      }
    },
    "owner": "yohannyoyo",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/c07df32b-55e2-4cf9-a7ba-41e260c6b473"
    }
  }
}
